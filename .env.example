APP_TITLE=HW Monitor
AUTH_PASS=change-me
SECRET_KEY=replace-with-long-random-string

HOST=0.0.0.0
PORT=8181

COLLECT_INTERVAL_SEC=1.0
SMART_TTL_SEC=60
CMD_TIMEOUT_SEC=4.0
RING_BUFFER_SIZE=300
SMART_DEVICES=auto
ENABLE_NVIDIA=auto
ENABLE_AMD=auto
ENABLE_INTEL=auto

DB_PATH=/var/lib/hw_monitor/history.db
HISTORY_RETENTION_DAYS=14

# Example: in4:+12V:12,in1:+5V:5
VOLTAGE_MAPPING=

LOG_LEVEL=INFO
